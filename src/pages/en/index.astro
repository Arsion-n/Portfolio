---
import Layout from '../../layouts/Layout.astro'
---

<Layout
  lang="en-HK"
  title="Arison N. | Portfolio"
  description="Arison N. – Civil Engineering Student & Interior Designer. View my projects, experience, and skills."
>
  <h1 class="visuallyhidden">Arison N. – Civil Engineering Student & Interior Designer</h1>

  <div class="showcase">
    <section class="showcase-section">
      <div class="unit-wrapper hero theme-light">
        <a class="unit-link" href="/en/about/" aria-hidden="true" tabindex="-1">&nbsp;</a>
        <div class="unit-copy">
          <h2 class="unit-headline">Arison N.</h2>
          <p class="unit-subhead">Civil Engineering Student & Interior Designer based in Hong Kong.</p>
          <div class="cta-links">
            <a class="btn btn-primary" href="/en/projects/">View Projects</a>
            <a class="btn btn-secondary" href="/en/about/">About Me</a>
          </div>
        </div>
      </div>
    </section>

    <section class="showcase-section">
      <div class="unit-wrapper theme-light">
        <a class="unit-link" href="/en/projects/" aria-hidden="true" tabindex="-1">&nbsp;</a>
        <div class="unit-copy">
          <h2 class="unit-headline">Project A</h2>
          <p class="unit-subhead">A brief description of this project and what makes it stand out.</p>
          <div class="cta-links">
            <a class="btn btn-primary" href="/en/projects/">Learn More</a>
          </div>
        </div>
        <div class="unit-image-wrapper">
          <img class="unit-image" src="/images/projects/project-a.jpg" alt="Project A" />
        </div>
      </div>
    </section>

    <div class="promo-grid">
      <a class="promo-card theme-light" href="/en/projects/">
        <div class="unit-copy">
          <h2 class="promo-headline">Project B</h2>
          <p class="promo-subhead">Short description of the project scope and outcome.</p>
        </div>
        <img class="promo-image" src="/images/projects/project-b.jpg" alt="Project B" />
      </a>
      <a class="promo-card theme-light" href="/en/projects/">
        <div class="unit-copy">
          <h2 class="promo-headline">Project C</h2>
          <p class="promo-subhead">Short description of the project scope and outcome.</p>
        </div>
        <img class="promo-image" src="/images/projects/project-c.jpg" alt="Project C" />
      </a>
    </div>
  </div>
</Layout>

<style>
  @import '../../styles/main.css';
</style>
