---
import Layout from '../../../layouts/Layout.astro'

const localNav = {
  title: 'About',
  items: [
    { label: 'Introduction', href: '#introduction' },
    { label: 'Education', href: '#education' },
    { label: 'Experience', href: '#experience' },
    { label: 'Skills', href: '#skills' },
    { label: 'Interests', href: '#interests' },
    { label: 'CV Download', href: '#cv-download' },
  ],
};
---

<Layout
  lang="en-HK"
  title="About | Arison N."
  description="About Arison N. – Civil Engineering student & Interior Designer based in Hong Kong."
  localNav={localNav}
>
  <section id="introduction" class="about-hero">
    <div class="about-hero-photo-container">
      <figure class="about-hero-photo">
        <img
          src="/images/about/portrait.jpg"
          alt="Arison N."
          loading="eager"
        />
      </figure>
    </div>
    <div class="about-hero-inner">
      <div class="about-hero-headlines">
        <h1 class="about-hero-title">NG Sheung Hang, Arison</h1>
        <h2 class="about-hero-role">Civil Engineering • Interior Design</h2>
      </div>
    </div>
  </section>

  <section class="about-section--bio">
    <div class="about-bio-inner">
      <p class="about-bio-body">
        I am an undergraduate Civil Engineering student with Interior Design background.
        After graduating from the Higher Diploma in Interior Design,
        I initially pursued a Bachelor's degree in Interior Architecture and Design.
        However, driven by a desire to master structural mechanics and contribute to larger-scale projects,
        I decided to pivot my path to Civil Engineering.
      </p>
      <p class="about-bio-body">
        During my transition period, I continued to hone my design skills as an InteSrior Design Assistant
        at a local studio, and as a co-worker of the Communication &amp; Interior Design team at IKEA Hong Kong.
      </p>
    </div>
  </section>

  <section id="education" class="about-specs">
    <h2 class="about-specs-title">Education</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Degree Programme</h3>
        <p class="about-specs-item">Programme and institution details will appear here.</p>
        <p class="about-specs-item">Expected graduation date.</p>
      </div>
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Previous Qualification</h3>
        <p class="about-specs-item">Previous academic background will be detailed here.</p>
        <p class="about-specs-item">Graduation date.</p>
      </div>
    </div>
  </section>

  <section id="experience" class="about-specs">
    <h2 class="about-specs-title">Experience</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Work Experience</h3>
        <p class="about-specs-item">Project highlights, design process, and selected works will be showcased here.</p>
      </div>
    </div>
  </section>

  <section id="skills" class="about-specs">
    <h2 class="about-specs-title">Skills</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Technical Skills</h3>
        <p class="about-specs-item">Technical skills, software tools, and interdisciplinary strengths will be listed here.</p>
      </div>
    </div>
  </section>

  <section id="interests" class="about-specs">
    <h2 class="about-specs-title">Interests</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Personal Interests</h3>
        <p class="about-specs-item">Personal interests and creative pursuits will be shared here.</p>
      </div>
    </div>
  </section>

  <section id="cv-download" class="about-specs">
    <h2 class="about-specs-title">CV Download</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">Download</h3>
        <p class="about-specs-item">A downloadable version of the CV will be available here.</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @import '../../../styles/about.css';
</style>
