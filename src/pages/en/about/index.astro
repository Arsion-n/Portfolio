---
import Layout from '../../../layouts/Layout.astro'

const localNav = {
  title: 'About',
  items: [
    { label: 'Introduction', href: '#introduction' },
    { label: 'Education', href: '#education' },
    { label: 'Experience', href: '#experience' },
    { label: 'Skills', href: '#skills' },
    { label: 'Interests', href: '#interests' },
    { label: 'CV Download', href: '#cv-download' },
  ],
};
---

<Layout
  lang="en-HK"
  title="About | Arison N."
  description="About Arison N. – Civil Engineering student & Interior Designer based in Hong Kong."
  localNav={localNav}
>
  <section id="introduction" class="about-hero">
    <div class="about-hero-photo-container">
      <figure class="about-hero-photo">
        <img
          src="/images/about/portrait.jpg"
          alt="Arison N."
          loading="eager"
        />
      </figure>
    </div>
    <div class="about-hero-inner">
      <div class="about-hero-headlines">
        <h1 class="about-hero-title">NG Sheung Hang, Arison</h1>
        <h2 class="about-hero-role">Civil Engineering • Interior Design</h2>
      </div>
    </div>
  </section>

  <section class="about-section--bio">
    <div class="about-bio-inner">
      <p class="about-bio-body">
        I am an undergraduate Civil Engineering student and an Interior Designer based in Hong Kong.
        After earning my Higher Diploma in Interior Design, I initially pursued a Bachelor's degree in Interior Architecture.
        However, driven by a desire to master structural mechanics and contribute to larger-scale projects,
        I decided to pivot my path to Civil Engineering.
      </p>
      <p class="about-bio-body">
        During my transition period, I continued to hone my design skills as a part-time Interior Design Assistant
        at a local studio, and as a member of the Communication &amp; Interior Design team at IKEA Hong Kong.
      </p>
    </div>
  </section>

  <section id="education" class="about-section">
    <h2 class="about-section-title">Education</h2>
    <p class="about-section-body">
      Academic background and qualifications will be detailed here.
    </p>
  </section>

  <section id="experience" class="about-section">
    <h2 class="about-section-title">Experience</h2>
    <p class="about-section-body">
      Project highlights, design process, and selected works will be showcased here.
    </p>
  </section>

  <section id="skills" class="about-section">
    <h2 class="about-section-title">Skills</h2>
    <p class="about-section-body">
      Technical skills, software tools, and interdisciplinary strengths will be listed here.
    </p>
  </section>

  <section id="interests" class="about-section">
    <h2 class="about-section-title">Interests</h2>
    <p class="about-section-body">
      Personal interests and creative pursuits will be shared here.
    </p>
  </section>

  <section id="cv-download" class="about-section about-section--last">
    <h2 class="about-section-title">CV Download</h2>
    <p class="about-section-body">
      A downloadable version of the CV will be available here.
    </p>
  </section>
</Layout>

<style>
  @import '../../../styles/about.css';
</style>
