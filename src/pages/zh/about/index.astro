---
import Layout from '../../../layouts/Layout.astro'

const localNav = {
  title: '關於',
  items: [
    { label: '自我介紹', href: '#introduction' },
    { label: '學歷', href: '#education' },
    { label: '經歷', href: '#experience' },
    { label: '技能', href: '#skills' },
    { label: '興趣', href: '#interests' },
    { label: '履歷下載', href: '#cv-download' },
  ],
};
---

<Layout
  lang="zh-HK"
  title="關於 | Arison N."
  description="Arison N. 關於頁 – 現居香港，主修土木工程，專注於室內設計與空間敘事。"
  localNav={localNav}
>
  <section id="introduction" class="about-hero">
    <div class="about-hero-photo-container">
      <figure class="about-hero-photo">
        <img
          src="/images/about/portrait.jpg"
          alt="Arison N."
          loading="eager"
        />
      </figure>
    </div>
    <div class="about-hero-inner">
      <div class="about-hero-headlines">
        <h1 class="about-hero-title">吳尚恒 Arison</h1>
        <h2 class="about-hero-role">土木工程學生 · 室內設計師</h2>
      </div>
    </div>
  </section>

  <section class="about-section--bio">
    <div class="about-bio-inner">
      <p class="about-bio-body">
        現居香港，主修土木工程，並專注於室內設計與空間敘事。
      </p>
    </div>
  </section>

  <section id="education" class="about-specs">
    <h2 class="about-specs-title">學歷</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">學位課程</h3>
        <p class="about-specs-item">課程及院校資料將在此顯示。</p>
        <p class="about-specs-item">預計畢業日期。</p>
      </div>
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">過往學歷</h3>
        <p class="about-specs-item">過往學術背景將在此詳列。</p>
        <p class="about-specs-item">畢業日期。</p>
      </div>
    </div>
  </section>

  <section id="experience" class="about-specs">
    <h2 class="about-specs-title">經歷</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">工作經驗</h3>
        <p class="about-specs-item">這裡將整理專案亮點、設計流程與代表作品。</p>
      </div>
    </div>
  </section>

  <section id="skills" class="about-specs">
    <h2 class="about-specs-title">技能</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">技術能力</h3>
        <p class="about-specs-item">這裡將展示軟體工具、技術能力與跨領域整合優勢。</p>
      </div>
    </div>
  </section>

  <section id="interests" class="about-specs">
    <h2 class="about-specs-title">興趣</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">個人興趣</h3>
        <p class="about-specs-item">個人興趣與創意追求將在此分享。</p>
      </div>
    </div>
  </section>

  <section id="cv-download" class="about-specs">
    <h2 class="about-specs-title">履歷下載</h2>
    <div class="about-specs-content">
      <div class="about-specs-group">
        <h3 class="about-specs-group-title">下載</h3>
        <p class="about-specs-item">可下載版本的履歷將在此提供。</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  @import '../../../styles/about.css';
</style>
