---
import { localizeHref } from '../utils/locale';

const pathname = Astro.url.pathname;
const lh = (href: string) => localizeHref(pathname, href);

const footerColumns = [
  {
    groups: [
      {
        title: 'Explore',
        links: [
          { label: 'Projects', href: '/projects/' },
          { label: 'Featured Work', href: '/projects/' },
        ],
      },
      {
        title: 'Portfolio',
        links: [
          { label: 'Case Studies', href: '/projects/' },
          { label: 'Design Notes', href: '/projects/' },
        ],
      },
    ],
  },
  {
    groups: [
      {
        title: 'Account',
        links: [
          { label: 'About Me', href: '/about/' },
          { label: 'CV (Coming Soon)', href: '/about/' },
        ],
      },
      {
        title: 'Updates',
        links: [
          { label: 'Latest News (Soon)', href: '/' },
          { label: 'Announcements (Soon)', href: '/' },
        ],
      },
    ],
  },
  {
    groups: [
      {
        title: 'Studio',
        links: [
          { label: 'Contact', href: '#site-footer' },
          { label: 'Work Process', href: '/about/' },
        ],
      },
      {
        title: 'Support',
        links: [
          { label: 'FAQ (Soon)', href: '/' },
          { label: 'Collaboration', href: '/about/' },
        ],
      },
    ],
  },
  {
    groups: [
      {
        title: 'Business',
        links: [
          { label: 'Commercial Projects', href: '/projects/' },
          { label: 'Partnerships', href: '/about/' },
        ],
      },
      {
        title: 'Education',
        links: [
          { label: 'Academic Works', href: '/projects/' },
          { label: 'Learning Journey', href: '/about/' },
        ],
      },
      {
        title: 'Public Sector',
        links: [
          { label: 'Urban Concepts', href: '/projects/' },
          { label: 'Community Design', href: '/projects/' },
        ],
      },
    ],
  },
  {
    groups: [
      {
        title: 'Values',
        links: [
          { label: 'Design Principles', href: '/about/' },
          { label: 'Sustainability', href: '/about/' },
        ],
      },
      {
        title: 'About Arison',
        links: [
          { label: 'Story', href: '/about/' },
          { label: 'Career Path', href: '/about/' },
        ],
      },
    ],
  },
];
---

<footer id="site-footer" role="contentinfo">
  <div class="footer-content">
    <nav class="footer-nav" aria-label="Site directory">
      <div class="footer-directory footer-directory--desktop">
        {footerColumns.map((column) => (
          <div class="footer-directory-column">
            {column.groups.map((group) => (
              <div class="footer-directory-section">
                <h3 class="footer-section-title">{group.title}</h3>
                <ul class="footer-section-list">
                  {group.links.map((link) => (
                    <li><a href={lh(link.href)}>{link.label}</a></li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
      <div class="footer-directory footer-directory--mobile">
        {footerColumns.map((column) => (
          <div class="footer-directory-column">
            {column.groups.map((group) => (
              <details class="footer-directory-section footer-accordion">
                <summary class="footer-section-title">
                  <span>{group.title}</span>
                  <svg class="footer-section-chevron" viewBox="0 0 11 6" aria-hidden="true">
                    <polyline points="10.075 0.675 5.5 5.323 0.925 0.675" />
                  </svg>
                </summary>
                <ul class="footer-section-list">
                  {group.links.map((link) => (
                    <li><a href={lh(link.href)}>{link.label}</a></li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        ))}
      </div>
    </nav>

    <section class="footer-bottom">
      <div class="footer-copyright">
        Copyright &copy; {new Date().getFullYear()} Arison N. All rights reserved.
      </div>
    </section>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    margin-top: 2rem;
    background-color: #f5f5f7;
    color: var(--color-text-secondary);
    font-size: 12px;
    line-height: 1.333;
    letter-spacing: -.01em;
  }

  .footer-content {
    max-width: var(--nav-max-width);
    margin: 0 auto;
    padding-inline-start: max(var(--nav-padding-inline), env(safe-area-inset-left));
    padding-inline-end: max(var(--nav-padding-inline), env(safe-area-inset-right));
  }

  .footer-nav {
    padding-top: 20px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(0, 0, 0, .12);
  }

  .footer-directory--desktop {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    column-gap: 32px;
    row-gap: 0;
  }

  .footer-directory--mobile {
    display: none;
  }

  .footer-directory-column {
    min-width: 0;
  }

  .footer-directory-section ~ .footer-directory-section {
    padding-top: 20px;
  }

  .footer-section-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: -.01em;
    line-height: 1.333;
    color: var(--color-text-label);
    margin: 0 0 .6em;
  }

  .footer-section-chevron {
    display: none;
    width: 11px;
    height: 6px;
    flex-shrink: 0;
    color: var(--color-text-secondary);
    transition: transform .24s ease;
  }

  .footer-section-chevron polyline {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .footer-directory--mobile .footer-accordion > summary {
    list-style: none;
    cursor: pointer;
  }

  .footer-directory--mobile .footer-accordion > summary::-webkit-details-marker {
    display: none;
  }

  .footer-section-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-section-list li {
    margin-bottom: .8em;
  }

  .footer-section-list a {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color .32s cubic-bezier(.4, 0, .6, 1);
  }

  .footer-section-list a:hover {
    color: var(--color-text-label);
    text-decoration: underline;
  }

  .footer-bottom {
    padding: 17px 0;
    padding-bottom: max(17px, env(safe-area-inset-bottom));
  }

  .footer-copyright {
    color: var(--color-text-tertiary);
  }

  @media screen and (max-width: 849px) {
    .footer-directory--desktop {
      display: none;
    }

    .footer-directory--mobile {
      display: grid;
      grid-template-columns: 1fr;
      row-gap: 0;
    }

    .footer-directory--mobile .footer-directory-column {
      min-width: 100%;
    }

    .footer-directory--mobile .footer-directory-column ~ .footer-directory-column {
      padding-top: 0;
    }

    .footer-directory--mobile .footer-directory-section {
      border-top: 1px solid rgba(0, 0, 0, .12);
      padding: 0;
    }

    .footer-directory--mobile .footer-directory-section ~ .footer-directory-section {
      padding-top: 0;
    }

    .footer-directory--mobile .footer-section-title {
      margin: 0;
      padding: 12px 0;
    }

    .footer-directory--mobile .footer-section-chevron {
      display: block;
    }

    .footer-directory--mobile .footer-accordion[open] .footer-section-chevron {
      transform: rotate(180deg);
    }

    .footer-directory--mobile .footer-accordion .footer-section-list {
      padding: 0 0 12px;
    }
  }

  @media screen and (min-width: 850px) {
    .footer-directory--desktop .footer-section-title {
      cursor: default;
    }
  }
</style>
