---
import { navItems, getFlatChildren } from '../data/navData';
---

<div id="mobile-menu" class="nav-links nav-mobile">
  {navItems.map((item, index) =>
    item.groups?.length ? (
      <div class="mobile-nav-group" style={`--item-index: ${index}`}>
        <button class="mobile-nav-trigger" aria-expanded="false">
          <span>{item.label}</span>
          <svg class="mobile-nav-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="mobile-nav-submenu">
          {getFlatChildren(item).map((child) => (
            <a href={child.href}>{child.label}</a>
          ))}
        </div>
      </div>
    ) : (
      <a href={item.href} style={`--item-index: ${index}`}>{item.label}</a>
    )
  )}
</div>
